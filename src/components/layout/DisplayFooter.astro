---

<footer class="relative py-[40px] px-[20px] bg-black border-t border-stone-800
               before:content-[''] before:absolute before:top-0 before:left-0 
               before:w-full before:h-[1px] 
               before:bg-gradient-to-r before:from-black before:via-amber-400 before:to-black">
    <div class="max-w-6xl mx-auto">
        <div class="flex flex-col items-center text-center space-y-4">
            <!-- Logo/Brand -->
            <div class="flex items-center space-x-3">
                <div class="w-6 h-6 border-2 border-amber-400 rotate-45 flex items-center justify-center">
                    <div class="w-1.5 h-1.5 bg-amber-400" style="transform: rotate(-45deg);"></div>
                </div>
                <span class="text-white font-mono text-lg">Compendium</span>
                <span class="text-stone-600">/</span>
                <span class="text-stone-500 text-sm font-mono tracking-wider">UI KIT</span>
            </div>
            
            <!-- Description -->
            <p class="text-stone-400 font-mono text-sm max-w-md leading-relaxed">
                A curated collection of reusable UI components built for modern web development. 
                Crafted with Astro, TypeScript, and Tailwind CSS.
            </p>
            
            <!-- Tech Stack -->
            <div class="flex items-center space-x-6 text-xs font-mono uppercase tracking-wider">
                <span class="text-amber-400">Astro</span>
                <span class="text-stone-600">•</span>
                <span class="text-rose-400">TypeScript</span>
                <span class="text-stone-600">•</span>
                <span class="text-emerald-400">Tailwind CSS</span>
            </div>
            
            <!-- Copyright -->
            <div class="pt-4 border-t border-stone-800 w-full">
                <p class="text-stone-600 text-xs font-mono">
                    Built with modern web technologies for developers who value quality and performance.
                </p>
            </div>
        </div>
    </div>
</footer>