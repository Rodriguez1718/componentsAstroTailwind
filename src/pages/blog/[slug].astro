---
import { getCollection, type CollectionEntry, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  console.log('Available blog posts:', posts.map(p => ({ id: p.id, title: p.data.title }))); // Debug log
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

interface Props {
  post: CollectionEntry<'blog'>;
}

const { post } = Astro.props;
const { Content } = await render(post);
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300..700;1,300..700&family=DM+Sans:ital,opsz,wght@0,9..40,100..1000;1,9..40,100..1000&family=Jost:ital@0;1&family=Playfair+Display:ital,wght@0,400..900;1,400..900&family=Poppins:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
		<title>{post.data.title} - Blog</title>
	</head>
	<style>
		@import "tailwindcss";
	</style>
	<body class="font-poppins bg-black">
		<main class="max-w-4xl mx-auto px-6 py-12 flex justify-center">
			<article class="prose prose-invert prose-lg max-w-none">
				<header class="mb-8 border border-b-[grey] flex flex-col">
                    <a href="/#markdown" class={`group back mb-4 text-stone-700 font-mono hover:underline hover:underline-offset-4 transition-colors duration-200 ${
						post.data.accent === 'amber' ? 'hover:text-amber-400'  :
						post.data.accent === 'rose' ? 'hover:text-rose-400' :
						post.data.accent === 'emerald' ? 'hover:text-emerald-400' :
						'hover:text-sky-400'
					}`}><span class="inline-block transition-transform duration-300 group-hover:-translate-x-2">←</span> Back to all posts</a>
					<span class={`self-start inline-block font-mono text-xs font-bold tracking-widest uppercase px-3 py-1 mb-4 ${
						post.data.accent === 'amber' ? 'bg-amber-400 text-stone-950' :
						post.data.accent === 'rose' ? 'bg-rose-400 text-stone-950' :
						post.data.accent === 'emerald' ? 'bg-emerald-400 text-stone-950' :
						'bg-sky-400 text-stone-950'
					}`}>
						{post.data.tag}
					</span>
					<h1 class="text-white text-4xl md:text-6xl font-['Playfair_Display',serif] mb-2">{post.data.title}</h1>
					<p class={`mb-8 font-mono text-sm uppercase tracking-wider ${
						post.data.accent === 'amber' ? 'text-amber-400' :
						post.data.accent === 'rose' ? 'text-rose-400' :
						post.data.accent === 'emerald' ? 'text-emerald-400' :
						'text-sky-400'
					}`}>
						{post.data.subtitle}
					</p>
				</header>
				
				<div class="text-stone-300 leading-relaxed">
					<Content />
				</div>
			</article>
		</main>
	</body>
</html>